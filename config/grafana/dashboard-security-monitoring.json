{
  "dashboard": {
    "id": null,
    "title": "Automator Web IA - Security Monitoring",
    "tags": ["automator", "security", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Security Overview",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Authentication Attempts",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(automator_auth_attempts_total[5m]))",
            "legendFormat": "Auth Attempts/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1}
      },
      {
        "id": 3,
        "title": "Failed Authentications",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(automator_auth_attempts_total{result=\"failure\"}[5m])",
            "legendFormat": "Failed Auth/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1}
      },
      {
        "id": 4,
        "title": "Security Incidents",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(automator_security_incidents_total[5m]))",
            "legendFormat": "Incidents/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 0.1},
                {"color": "red", "value": 1}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1}
      },
      {
        "id": 5,
        "title": "Vulnerabilities Found",
        "type": "stat",
        "targets": [
          {
            "expr": "automator_vulnerabilities_found",
            "legendFormat": "Active Vulnerabilities"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 5},
                {"color": "red", "value": 20}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1}
      },
      {
        "id": 6,
        "title": "Authentication Trends",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(automator_auth_attempts_total{result=\"success\"}[5m])",
            "legendFormat": "Successful Auth"
          },
          {
            "expr": "rate(automator_auth_attempts_total{result=\"failure\"}[5m])",
            "legendFormat": "Failed Auth"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5}
      },
      {
        "id": 7,
        "title": "Security Incidents by Type",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(automator_security_incidents_total[5m])",
            "legendFormat": "{{incident_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5}
      },
      {
        "id": 8,
        "title": "Audit Events",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(automator_audit_events_total[5m])",
            "legendFormat": "{{event_type}} - {{severity}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13}
      },
      {
        "id": 9,
        "title": "Encryption Operations",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(automator_encryption_operations_total{result=\"success\"}[5m])",
            "legendFormat": "Successful {{operation_type}}"
          },
          {
            "expr": "rate(automator_encryption_operations_total{result=\"failure\"}[5m])",
            "legendFormat": "Failed {{operation_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13}
      },
      {
        "id": 10,
        "title": "Security Alerts",
        "type": "table",
        "targets": [
          {
            "expr": "automator_security_incidents_total",
            "legendFormat": "{{incident_type}}",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "color-background"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 21}
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}
